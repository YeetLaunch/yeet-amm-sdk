{
  "name": "@yeetlaunch/yeet-amm-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the YeetAMM program — PDA derivation, instruction builders, account decoding, error decoding, and a thin REST client. Pricing is served by the YeetLaunch API; no curve math is included.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": ["solana", "yeetamm", "yeetlaunch", "amm", "dex", "sdk"],
  "peerDependencies": {
    "@solana/web3.js": "^1.87.0",
    "@solana/spl-token": "^0.4.0"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.9",
    "typescript": "^5.4.0"
  }
}
